---
import MobileMenuToggle from '@astrojs/starlight/components/MobileMenuToggle.astro';
import type { Props } from '@astrojs/starlight/props';
import PlusEditionTopBanner from './PlusEditionTopBanner.astro';

const { hasSidebar, labels } = Astro.props as Props;
---

<div class="page sl-flex">
	<header class="header">
		<PlusEditionTopBanner lang={Astro.props.lang} />
		<div class="navbar"><slot name="header" /></div>
	</header>
	{
		hasSidebar && (
			<nav class="sidebar" aria-label={labels['sidebarNav.accessibleLabel']}>
				<MobileMenuToggle {...Astro.props} />
				<div id="starlight__sidebar" class="sidebar-pane">
					<div class="sidebar-content sl-flex">
						<slot name="sidebar" />
					</div>
				</div>
			</nav>
		)
	}
	<div class="main-frame"><slot /></div>
</div>

<style>
	:global(:root) {
		--plus-banner-height: 2.75rem;
		--plus-header-height: calc(var(--sl-nav-height) + var(--plus-banner-height));
	}

	.page {
		flex-direction: column;
		min-height: 100vh;
	}

	.header {
		z-index: var(--sl-z-index-navbar);
		position: fixed;
		inset-inline-start: 0;
		inset-block-start: 0;
		width: 100%;
		height: var(--plus-header-height);
		border-bottom: 1px solid var(--sl-color-hairline-shade);
		background-color: var(--sl-color-bg-nav);
	}

	.navbar {
		height: var(--sl-nav-height);
		padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
		padding-inline-end: var(--sl-nav-pad-x);
	}

	:global([data-has-sidebar]) .navbar {
		padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
	}

	:global(starlight-menu-button button) {
		top: calc(var(--plus-banner-height) + (var(--sl-nav-height) - var(--sl-menu-button-size)) / 2);
	}

	.sidebar-pane {
		visibility: var(--sl-sidebar-visibility, hidden);
		position: fixed;
		z-index: var(--sl-z-index-menu);
		inset-block: var(--plus-header-height) 0;
		inset-inline-start: 0;
		width: 100%;
		background-color: var(--sl-color-black);
		overflow-y: auto;
	}

	:global([aria-expanded='true']) ~ .sidebar-pane {
		--sl-sidebar-visibility: visible;
	}

	.sidebar-content {
		height: 100%;
		min-height: max-content;
		padding: 1rem var(--sl-sidebar-pad-x) 0;
		flex-direction: column;
		gap: 1rem;
	}

	.main-frame {
		padding-top: calc(var(--plus-header-height) + var(--sl-mobile-toc-height));
		padding-inline-start: var(--sl-content-inline-start);
	}

	@media (min-width: 50rem) {
		:global([data-has-sidebar]) .navbar {
			padding-inline-end: var(--sl-nav-pad-x);
		}

		.sidebar-pane {
			--sl-sidebar-visibility: visible;
			width: var(--sl-sidebar-width);
			background-color: var(--sl-color-bg-sidebar);
			border-inline-end: 1px solid var(--sl-color-hairline-shade);
		}

		.sidebar-content::after {
			content: '';
			padding-bottom: 1px;
		}
	}
</style>
